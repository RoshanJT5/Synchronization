# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# React Native / Expo
.expo/
.expo-shared/
.metro/

# Android build artifacts
android/app/build/
android/build/
mobile/build/
mobile/android/app/build/
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/java_pid*.hprof
*.hprof
# Exclude raw APK/AAB build outputs but NOT web/downloads/ (served by Vercel)
mobile/build/**/*.apk
mobile/build/**/*.aab
*.aar

# iOS build artifacts
ios/build/
mobile/ios/build/
*.ipa

# Flutter tool artifacts
mobile/.dart_tool/
mobile/ephemeral/
mobile/.flutter-plugins-dependencies
mobile/.flutter-plugins

# IDE / Editor
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Environment
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Downloads and build artifacts
# Note: web/downloads/ is intentionally tracked so the APK and extension ZIP
# are served by Vercel. Only exclude the raw APK/AAB build outputs.
!web/downloads/
!web/downloads/**
extension/dist/